# Cloudflare Workers local dev values — copy to `.dev.vars` and fill in values.
# Non-sensitive defaults now live in `wrangler.toml` under `[vars]`.
# Put a value here only if it is sensitive or you want a local override.

BETTER_AUTH_URL = http://localhost:5173

# Sensitive values
AM_I_OK_SECRET=
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
NOTION_TOKEN=
OPENAI_API_KEY=
